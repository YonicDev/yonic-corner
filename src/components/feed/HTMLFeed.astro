---
import { getImage } from 'astro:assets';
import type { GetImageResult } from 'astro';

import {load} from 'cheerio';

import { getRemoteHeroImage } from '@lib/remote-images';

import "@lib/styles/article.scss";

interface Props {
    post: string,
    heroImage?: ImageMetadata | string,
    full: boolean,
}

const { post, heroImage, full } = Astro.props;

let finalHtml = "";

const html = await Astro.slots.render("html");
let $ = load(html, null, false);
const feedHtml = full? $.html() : $(".feed-preview").html();
if(feedHtml) {
    $ = load(feedHtml, null, false);
    $("p").each(function() {
        $(this).html($(this).html()!.replaceAll(/\n|\s\n/g, " "))
    })
    finalHtml = $.html();
}

/**
 * Gets the hero image.
 * 
 * The hero image has to be named "hero.png" and be located in the post folder.
 * It doesn't need to be a PNG image, other formats are supported.
 */
 async function getHeroImage(): Promise<GetImageResult | null> {
    try {
        const [year, month, id] = post.split("/");

        const imageMeta: ImageMetadata = heroImage ?? (year === "drafts" 
            ? (await import(`../../content/blog/${year}/${month}/hero.png`)).default
            : (await import(`../../content/blog/${year}/${month}/${id}/hero.png`)).default);
            
        return getImage({src: imageMeta, width: 768, format: "jpg", quality: 80});
    } catch {
        return null;
    }
}

let hero: string | null;
if(typeof heroImage === "string")
    hero = getRemoteHeroImage({src: heroImage });
else {
    const localImage = await getHeroImage()
    hero = localImage ? import.meta.env.SITE + localImage.src : null;
}

---
{hero && <figure><img alt="Cover image" src={hero} /><figcaption></figcaption></figure>}
<Fragment set:html={finalHtml} />
<a href={import.meta.env.SITE + "/blog/article/" + post}>Continue reading &rarr;</a>
