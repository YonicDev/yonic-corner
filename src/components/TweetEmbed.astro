<slot/>
<script is:inline>
    if(Modernizr.promises && document.getElementById("tweet-script") == null) {
        const theme = window.localStorage.getItem("theme");
        if(theme == "dark") {
            document.querySelectorAll("blockquote.twitter-tweet").forEach(function(element) {
                element.setAttribute("data-theme", "dark");
            });
            console.log(document.querySelectorAll("blockquote.twitter-tweet"));
        } else if ((theme == "auto" || theme == null) && window.matchMedia("(prefers-color-scheme: dark)").matches) {
            document.querySelectorAll("blockquote.twitter-tweet").forEach(function(element) {
                element.setAttribute("data-theme", "dark");
            });
        }
        const tweetScript = document.createElement("script");
        tweetScript.src = "//platform.twitter.com/widgets.js";
        tweetScript.id = "tweet-script"
        tweetScript.setAttribute("async", true);
        document.body.appendChild(tweetScript);
    }
</script>
